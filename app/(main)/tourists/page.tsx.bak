import { createClient } from "@/lib/supabase/server"
import { redirect } from "next/navigation"
import { TouristsList } from "@/components/tourists/tourists-list"

export default async function TouristsPage() {
  const supabase = await createClient()

  const {
    data: { user },
  } = await supabase.auth.getUser()

  if (!user) {
    redirect("/auth/login")
  }

  // 检查是否是导游
  const { data: profile } = await supabase.from("profiles").select("role").eq("id", user.id).single()

  if (profile?.role !== "guide") {
    redirect("/")
  }

  // 获取所有游客信息
  const { data: tourists } = await supabase
    .from("profiles")
    .select("*")
    .eq("role", "user")
    .order("created_at", { ascending: false })

  return (
    <div className="container mx-auto px-4 py-8">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-foreground">游客信息</h1>
        <p className="text-muted-foreground mt-2">查看注册游客的基本信息</p>
      </div>

      <TouristsList tourists={tourists || []} />
    </div>
  )
}
